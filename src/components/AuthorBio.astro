---
// The bio is a fixed copy block (mission-first, leading with the column).
// The previous version templated a per-article `topics` clause, but the new
// copy is intentionally not topic-specific — same bio at the bottom of every
// article. The `topics` prop is kept on the interface for backwards-compat
// with existing call sites but is no longer rendered.
interface Props {
  topics?: string[];
}
---

<aside class="author-bio" aria-label="About the author">
  <p>
    Shelly Lynn Xiong (also published as Shelly Xiong, online as
    <span class="author-bio-handle">@shellylynnx</span>) writes the NYC Subway
    Birder column at <a href="https://shellylynnx.com">shellylynnx.com</a>.
    She curates the <a href="/library/">Public Domain Bird Library</a>, a
    catalog of pre-1929 American bird literature, and built
    <a
      href="https://shellylynnx.github.io/projects/opera-glass/"
      target="_blank"
      rel="noopener noreferrer">Birds Through an Opera Glass</a>, an online
    edition of Florence Merriam Bailey's 1889 field guide with modern bird audio.
    She's an artist and the Website Administrator at
    <a
      href="https://www.metmuseum.org"
      target="_blank"
      rel="noopener noreferrer">The Metropolitan Museum of Art</a>.
  </p>
</aside>

<style>
  .author-bio {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .author-bio a {
    color: var(--color-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .author-bio a:hover {
    color: var(--color-highlight);
  }

  .author-bio-handle {
    font-weight: 500;
    color: var(--color-text);
  }
</style>
