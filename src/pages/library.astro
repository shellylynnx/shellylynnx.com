---
import BaseLayout from "../layouts/BaseLayout.astro";

const escScript = (s: string) => s.replace(/</g, "\\u003c");

const canonical = new URL("/library/", Astro.site).href;
const ogImage = "/images/shelly-avatar.jpg";

const title = "The Public Domain Bird Library";
const description =
  "A curated index of canonical public-domain American bird books with verified download links. NYC-rooted. Updated continuously.";

const lastUpdated = "April 26, 2026";
const dateModifiedISO = "2026-04-26";

// Per-author metadata used to enrich the JSON-LD nested Person object on
// each Book entry. `sameAs` points at Wikipedia (most authoritative
// general-purpose page); `iconSlug` resolves to the 64x64 portrait JPEG
// at /images/library/authors/<slug>-icon.jpg. Both fields are optional;
// JSON.stringify drops undefined properties cleanly.
const authorMeta: Record<string, { sameAs?: string; iconSlug?: string }> = {
  "Frank M. Chapman": {
    sameAs: "https://en.wikipedia.org/wiki/Frank_Chapman_(ornithologist)",
    iconSlug: "frank-m-chapman",
  },
  "C. Hart Merriam": {
    sameAs: "https://en.wikipedia.org/wiki/C._Hart_Merriam",
    iconSlug: "c-hart-merriam",
  },
  "John Burroughs": {
    sameAs: "https://en.wikipedia.org/wiki/John_Burroughs",
    iconSlug: "john-burroughs",
  },
  "Mabel Osgood Wright": {
    sameAs: "https://en.wikipedia.org/wiki/Mabel_Osgood_Wright",
    iconSlug: "mabel-osgood-wright",
  },
  "Witmer Stone": {
    sameAs: "https://en.wikipedia.org/wiki/Witmer_Stone",
    iconSlug: "witmer-stone",
  },
  "Florence Merriam Bailey": {
    sameAs: "https://en.wikipedia.org/wiki/Florence_Merriam_Bailey",
    iconSlug: "florence-merriam-bailey",
  },
  "Olive Thorne Miller": {
    sameAs: "https://en.wikipedia.org/wiki/Olive_Thorne_Miller",
    iconSlug: "olive-thorne-miller",
  },
  "Neltje Blanchan": {
    sameAs: "https://en.wikipedia.org/wiki/Neltje_Blanchan",
    iconSlug: "neltje-blanchan",
  },
  "Cordelia Stanwood": {
    sameAs: "https://en.wikipedia.org/wiki/Cordelia_Stanwood",
    iconSlug: "cordelia-stanwood",
  },
  "Althea Sherman": {
    sameAs: "https://en.wikipedia.org/wiki/Althea_Sherman",
    iconSlug: "althea-sherman",
  },
  "Margaret Morse Nice": {
    iconSlug: "margaret-morse-nice",
    // Nice is intentionally not given a Wikipedia sameAs here. No
    // Wikipedia article exists at the canonical English slug at the
    // time of writing; add when one ships.
  },
};

const ORIGIN = "https://shellylynnx.com";
const iconUrl = (slug: string) =>
  `${ORIGIN}/images/library/authors/${slug}-icon.jpg`;

// Books with verified year + canonical URL, used for the JSON-LD ItemList.
// Ordered by appearance on the page. Mirrors every distinctly-titled book
// entry rendered on the page. The Bird-Lore magazine entry is excluded
// (Periodical, not Book). Named titles with confident years are included
// even when they appear in a grouped "other titles" / "several others"
// bullet on the page; uncertain dates are intentionally omitted from the
// individual Book entries (JSON.stringify drops the property cleanly).
const books = [
  {
    name: "Handbook of Birds of Eastern North America",
    author: "Frank M. Chapman",
    datePublished: "1895",
    url: "https://archive.org/details/handbookofbirdso00chapuoft",
  },
  {
    name: "Bird-Life: A Guide to the Study of Our Common Birds",
    author: "Frank M. Chapman",
    datePublished: "1897",
    url: "https://archive.org/details/birdlifeguidecha00chap",
  },
  {
    name: "A Review of the Birds of Connecticut, with Remarks on their Habits",
    author: "C. Hart Merriam",
    datePublished: "1877",
    url: "https://www.biodiversitylibrary.org/creator/1398",
  },
  {
    name: "Results of a Biological Survey of the San Francisco Mountain Region and Desert of the Little Colorado, Arizona",
    author: "C. Hart Merriam",
    datePublished: "1890",
    url: "https://archive.org/details/resultsabiologi00stejgoog",
  },
  {
    // Year intentionally omitted: not given on the page or in the source
    // catalog. JSON.stringify drops the undefined property from output.
    name: "Circular on the Food-Habits of Birds",
    author: "C. Hart Merriam",
    url: "https://archive.org/details/circularonfoodha00merr",
  },
  {
    name: "Wake-Robin",
    author: "John Burroughs",
    datePublished: "1871",
    url: "https://www.gutenberg.org/ebooks/4203",
  },
  {
    name: "Locusts and Wild Honey",
    author: "John Burroughs",
    datePublished: "1879",
    url: "https://www.gutenberg.org/ebooks/author/1127",
  },
  {
    name: "Signs and Seasons",
    author: "John Burroughs",
    datePublished: "1886",
    url: "https://www.gutenberg.org/ebooks/author/1127",
  },
  {
    name: "Birds and Bees",
    author: "John Burroughs",
    datePublished: "1887",
    url: "https://www.gutenberg.org/ebooks/author/1127",
  },
  {
    // Year intentionally omitted: the title appears in multiple editions
    // (originally as a chapter in Locusts and Wild Honey, 1879; later as
    // a stand-alone D.C. Heath school edition). JSON.stringify drops
    // the undefined datePublished property from the output.
    name: "Sharp Eyes",
    author: "John Burroughs",
    url: "https://www.gutenberg.org/ebooks/author/1127",
  },
  {
    name: "Birdcraft: A Field Book of Two Hundred Song, Game, and Water Birds",
    author: "Mabel Osgood Wright",
    datePublished: "1895",
    url: "https://archive.org/details/birdcraftfieldbo01wrig",
  },
  {
    name: "The Making of Birdcraft Sanctuary",
    author: "Mabel Osgood Wright",
    datePublished: "1921",
    url: "https://archive.org/details/cu31924090201306",
  },
  {
    name: "The Birds of New Jersey",
    author: "Witmer Stone",
    datePublished: "1908",
    url: "https://archive.org/details/birdsofnewjersey00stonrich",
  },
  {
    name: "Annual Report of the New Jersey State Museum, 1901-1912, 1914",
    author: "Witmer Stone",
    // Year intentionally omitted: this is a multi-year compilation.
    url: "https://archive.org/details/annualreportofne00newj",
  },
  {
    name: "Birds Through an Opera Glass",
    author: "Florence Merriam Bailey",
    datePublished: "1889",
    url: "https://archive.org/details/birdsthroughopera00bailrich",
  },
  {
    name: "A-Birding on a Bronco",
    author: "Florence Merriam Bailey",
    datePublished: "1896",
    url: "https://www.gutenberg.org/files/33410/33410-h/33410-h.htm",
  },
  {
    name: "Birds of Village and Field: A Bird Book for Beginners",
    author: "Florence Merriam Bailey",
    datePublished: "1898",
    url: "https://archive.org/search.php?query=birds+of+village+and+field+bailey",
  },
  {
    name: "Handbook of Birds of the Western United States",
    author: "Florence Merriam Bailey",
    datePublished: "1902",
    url: "https://archive.org/search.php?query=handbook+birds+western+united+states+bailey",
  },
  {
    name: "Birds of New Mexico",
    author: "Florence Merriam Bailey",
    datePublished: "1928",
    url: "https://archive.org/search.php?query=birds+of+new+mexico+bailey",
  },
  {
    name: "Bird-Ways",
    author: "Olive Thorne Miller",
    datePublished: "1885",
    url: "https://archive.org/search.php?query=bird-ways+olive+thorne+miller",
  },
  {
    name: "In Nesting Time",
    author: "Olive Thorne Miller",
    datePublished: "1888",
    url: "https://archive.org/search.php?query=in+nesting+time+olive+thorne+miller",
  },
  {
    name: "A Bird-Lover in the West",
    author: "Olive Thorne Miller",
    datePublished: "1894",
    url: "https://archive.org/search.php?query=bird-lover+in+the+west+olive+thorne+miller",
  },
  {
    name: "Little Brothers of the Air",
    author: "Olive Thorne Miller",
    datePublished: "1892",
    url: "https://archive.org/search.php?query=creator%3A%22Olive+Thorne+Miller%22",
  },
  {
    name: "The Children's Book of Birds",
    author: "Olive Thorne Miller",
    datePublished: "1901",
    url: "https://archive.org/search.php?query=creator%3A%22Olive+Thorne+Miller%22",
  },
  {
    name: "The Second Book of Birds: Bird Families",
    author: "Olive Thorne Miller",
    datePublished: "1901",
    url: "https://archive.org/search.php?query=creator%3A%22Olive+Thorne+Miller%22",
  },
  {
    name: "True Bird Stories from My Note-Books",
    author: "Olive Thorne Miller",
    datePublished: "1903",
    url: "https://archive.org/search.php?query=creator%3A%22Olive+Thorne+Miller%22",
  },
  {
    name: "Bird Neighbors",
    author: "Neltje Blanchan",
    datePublished: "1897",
    url: "https://www.gutenberg.org/ebooks/37735",
  },
  {
    name: "Birds That Hunt and Are Hunted",
    author: "Neltje Blanchan",
    datePublished: "1898",
    url: "https://archive.org/details/birdsthathuntare00bla",
  },
  {
    name: "How to Attract the Birds",
    author: "Neltje Blanchan",
    datePublished: "1902",
    url: "https://archive.org/details/howtoattractbird00bla",
  },
  {
    name: "Birds Every Child Should Know",
    author: "Neltje Blanchan",
    datePublished: "1907",
    url: "https://gutenberg.org/files/38233/38233-h/38233-h.htm",
  },
];

const author = {
  "@type": "Person",
  "@id": "https://shellylynnx.com/#shelly",
  name: "Shelly Lynn Xiong",
  alternateName: ["Shelly Lynn", "Shelly Xiong", "NYC Subway Birder", "shellylynnx"],
  url: "https://shellylynnx.com",
  sameAs: [
    "https://shellylynnx.com",
    "https://www.tiktok.com/@shellylynnx",
    "https://www.instagram.com/shellylynnx/",
    "https://github.com/shellylynnx",
    "https://ebird.org/profile/NDQ0MjU4OA",
  ],
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  headline: title,
  description,
  url: canonical,
  inLanguage: "en-US",
  dateModified: dateModifiedISO,
  isPartOf: {
    "@type": "WebSite",
    name: "shellylynnx.com",
    url: "https://shellylynnx.com",
  },
  creator: author,
  about: {
    "@type": "Thing",
    name: "Public domain American ornithological literature, NYC-rooted curation",
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: books.length,
    itemListElement: books.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Book",
        name: b.name,
        author: {
          "@type": "Person",
          name: b.author,
          sameAs: authorMeta[b.author]?.sameAs,
          image: authorMeta[b.author]?.iconSlug
            ? iconUrl(authorMeta[b.author].iconSlug!)
            : undefined,
        },
        datePublished: b.datePublished,
        inLanguage: "en",
        url: b.url,
        bookFormat: "https://schema.org/EBook",
        accessMode: "textual",
        isAccessibleForFree: true,
        license: "https://creativecommons.org/publicdomain/mark/1.0/",
      },
    })),
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogTitle={title}
  ogDescription={description}
  ogImage={ogImage}
  ogImageAlt="Portrait of Shelly Xiong, NYC birder, artist, and developer."
  ogType="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={escScript(JSON.stringify(collectionSchema))}
  />

  <main style="padding-top: var(--nav-height);">
    <section class="section library-page" id="library">
      <div class="container" style="max-width: 720px;">
        <h1 class="section-title">The Public Domain Bird Library</h1>
        <p class="section-dek">
          A curated index of canonical public-domain American bird books, with
          verified download links. NYC-rooted. Continuously maintained.
        </p>

        <div class="library-body">
          <p>
            Most canonical American bird books from the 1870s through the late
            1920s are in the public domain. They are downloadable, quotable,
            screenshottable, embeddable, and reissuable without permission.
            This is a working catalog of the books I keep coming back to as a
            <a href="/subway-birder/">NYC birder</a>, with verified scans
            across the Internet Archive, Project Gutenberg, HathiTrust, the
            Biodiversity Heritage Library, and the Library of Congress. I
            read these to understand how the people who came before us
            thought about the birds we still see in Central Park. NYC and
            women in birdwatching first. More to come.
          </p>

          <p>
            Books are grouped by author, then chronologically within author.
            Each entry: title, year, one-line note on why it matters, primary
            download links, and any NYC connection.
          </p>

          <nav class="library-toc" aria-label="Authors on this page">
            <h3>On this page</h3>
            <ul>
              <li><a href="#frank-m-chapman">Frank M. Chapman</a></li>
              <li><a href="#c-hart-merriam">C. Hart Merriam</a></li>
              <li><a href="#john-burroughs">John Burroughs</a></li>
              <li><a href="#mabel-osgood-wright">Mabel Osgood Wright</a></li>
              <li><a href="#witmer-stone">Witmer Stone</a></li>
              <li>
                <a href="#florence-merriam-bailey">Florence Merriam Bailey</a>
              </li>
              <li><a href="#olive-thorne-miller">Olive Thorne Miller</a></li>
              <li><a href="#neltje-blanchan">Neltje Blanchan</a></li>
              <li><a href="#cordelia-stanwood">Cordelia Stanwood</a></li>
              <li><a href="#althea-sherman">Althea Sherman</a></li>
              <li>
                <a href="#margaret-morse-nice">Margaret Morse Nice</a>
              </li>
            </ul>
          </nav>

          <p>
            <strong>What public domain means here.</strong> Any U.S. work
            published before 1931 is in the public domain in 2026 (95-year
            rolling rule). That covers everything on this page. For the legal
            background, see the
            <a
              href="https://copyright.cornell.edu/publicdomain"
              target="_blank"
              rel="noopener noreferrer">Cornell Copyright Term and Public
              Domain chart</a>.
          </p>

          <h3 id="nyc-and-the-metro-region">NYC and the metro region</h3>
          <p class="library-section-dek">
            <em>The tri-state birding culture extends well past Manhattan:
            NJ Transit to Sandy Hook, Cape May, and the Great Swamp;
            Metro-North to the Hudson Highlands; LIRR to Jamaica Bay and
            Montauk. Authors below cover NYC institutions, the Hudson
            Valley, Connecticut, and the New Jersey coast.</em>
          </p>

          <h4 id="frank-m-chapman">Frank M. Chapman (1864&ndash;1945)</h4>
          <img class="author-icon" src="/images/library/authors/frank-m-chapman-icon.jpg" alt="Frank M. Chapman portrait" width="96" height="96" loading="lazy" />
          <p>
            Joined the American Museum of Natural History in 1888, Curator of
            Birds in 1908. Founded and edited <em>Bird-Lore</em> magazine
            starting in 1899. Originated the Audubon Christmas Bird Count. The
            NYC institutional voice of American ornithology for decades.
          </p>
          <ul class="library-titles">
            <li>
              <em>Handbook of Birds of Eastern North America</em> (1895). The
              NYC-area birder's bible. The most-used field reference in the
              Northeast before Peterson.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/handbookofbirdso00chapuoft"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (Toronto scan)</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/handbookbirdseas00chaprich"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (Cornell scan)</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/handbookofbi00chap"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (alt)</a>
                </li>
                <li>
                  <a
                    href="https://www.biodiversitylibrary.org/bibliography/14165"
                    target="_blank"
                    rel="noopener noreferrer">Biodiversity Heritage Library</a>
                </li>
                <li>
                  <a
                    href="https://www.loc.gov/item/12014730/"
                    target="_blank"
                    rel="noopener noreferrer">Library of Congress</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Bird-Life: A Guide to the Study of Our Common Birds</em>
              (1897). Beginner-friendly companion.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/birdlifeguidecha00chap"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/birdlifeguidetos00chaprich"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (alt)</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Bird-Lore</em> magazine (1899&ndash;1946). Founded by
              Chapman, edited from NYC. The forerunner to <em>Audubon</em>
              magazine.
              <ul>
                <li>
                  <a
                    href="https://www.biodiversitylibrary.org/bibliography/8259"
                    target="_blank"
                    rel="noopener noreferrer">BHL master bibliography</a>
                  (links to every volume)
                </li>
                <li>
                  <a
                    href="https://www.biodiversitylibrary.org/item/101389"
                    target="_blank"
                    rel="noopener noreferrer">BHL Vol. 1 (1899)</a>
                </li>
                <li>
                  <a
                    href="https://digitalcommons.usf.edu/sora/"
                    target="_blank"
                    rel="noopener noreferrer">SORA full-text search</a>
                  across the run.
                </li>
              </ul>
            </li>
          </ul>

          <h4 id="c-hart-merriam">C. Hart Merriam (1855&ndash;1942)</h4>
          <img class="author-icon" src="/images/library/authors/c-hart-merriam-icon.jpg" alt="C. Hart Merriam portrait" width="96" height="96" loading="lazy" />
          <p>
            Clinton Hart Merriam. Born Lewis County, NY. Co-founder of the
            <a
              href="https://www.linnaeannewyork.org"
              target="_blank"
              rel="noopener noreferrer">Linnaean Society of New York</a>
            (1878). Founding member of the AOU (1883, at AMNH), elected its
            first secretary; president of the AOU in 1902. Founder and
            first chief of the U.S. Biological Survey (1885), the agency
            that became the U.S. Fish and Wildlife Service. Developed the
            "life zones" classification system for North American flora and
            fauna. Began his career as an ornithologist before pivoting to
            mammalogy, becoming widely known as the "father of American
            mammalogy." Florence Merriam Bailey's older brother.
          </p>
          <ul class="library-titles">
            <li>
              <em>A Review of the Birds of Connecticut, with Remarks on
              their Habits</em> (1877). His first major scientific work,
              published at age 22. Recognized that bird ranges are
              governed by breeding-season temperature, an early
              formulation of what became his life-zones theory.
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=birds+of+connecticut+merriam"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
                <li>
                  <a
                    href="https://www.biodiversitylibrary.org/creator/1398"
                    target="_blank"
                    rel="noopener noreferrer">Biodiversity Heritage Library
                    (Merriam creator page)</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Results of a Biological Survey of the San Francisco
              Mountain Region and Desert of the Little Colorado,
              Arizona</em> (1890, with Leonhard Stejneger). A multi-part
              survey including general results, the Grand Ca&ntilde;on of
              the Colorado, an annotated list of mammals, and an
              annotated list of birds (Section 4). The first major output
              of his "life zones" research.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/resultsabiologi00stejgoog"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Circular on the Food-Habits of Birds</em>. Biological
              Survey publication on bird diet, an early example of
              applied ornithology.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/circularonfoodha00merr"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
              </ul>
            </li>
            <li>
              Author master indexes:
              <a
                href="https://openlibrary.org/authors/OL155108A/C._Hart_Merriam"
                target="_blank"
                rel="noopener noreferrer">Open Library</a>,
              <a
                href="https://www.biodiversitylibrary.org/creator/1398"
                target="_blank"
                rel="noopener noreferrer">Biodiversity Heritage Library</a>,
              <a
                href="https://www.loc.gov/collections/c-hart-merriam-papers/"
                target="_blank"
                rel="noopener noreferrer">Library of Congress C. Hart
                Merriam Papers</a>. His larger mammalogy output (including
              <em>The Mammals of the Adirondack Region</em>, 1884, and
              the Biological Survey monographs on North American mammals)
              is fully public domain and accessible via the BHL creator
              page and the Library of Congress collection above.
            </li>
          </ul>

          <h4 id="john-burroughs">John Burroughs (1837&ndash;1921)</h4>
          <img class="author-icon" src="/images/library/authors/john-burroughs-icon.jpg" alt="John Burroughs portrait" width="96" height="96" loading="lazy" />
          <p>
            Hudson Valley nature writer, Catskills. Florence Merriam Bailey
            invited him to Smith College in 1886. Co-founder of the
            <a
              href="https://www.linnaeannewyork.org"
              target="_blank"
              rel="noopener noreferrer">Linnaean Society of New York</a>
            (1878), alongside C. Hart Merriam. The patron saint of American
            nature writing.
          </p>
          <ul class="library-titles">
            <li>
              <em>Wake-Robin</em> (1871). The book that arguably invented
              popular American nature writing as a genre.
              <ul>
                <li>
                  <a
                    href="https://www.gutenberg.org/ebooks/4203"
                    target="_blank"
                    rel="noopener noreferrer">Project Gutenberg eBook</a>
                  (cleanest plain-text and EPUB)
                </li>
                <li>
                  <a
                    href="https://www.gutenberg.org/files/4203/4203-h/4203-h.htm"
                    target="_blank"
                    rel="noopener noreferrer">Project Gutenberg HTML edition</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/wakerobi00burr"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
                <li>
                  <a
                    href="https://catalog.hathitrust.org/Record/005239480"
                    target="_blank"
                    rel="noopener noreferrer">HathiTrust</a>
                </li>
                <li>
                  <a
                    href="https://www.loc.gov/item/16000036/"
                    target="_blank"
                    rel="noopener noreferrer">Library of Congress</a>
                </li>
              </ul>
            </li>
            <li>
              Other Burroughs titles (<em>Birds and Bees</em>,
              <em>Sharp Eyes</em>, <em>Locusts and Wild Honey</em>,
              <em>Signs and Seasons</em>, etc.), all public domain.
              <ul>
                <li>
                  <a
                    href="https://www.gutenberg.org/ebooks/author/1127"
                    target="_blank"
                    rel="noopener noreferrer">Burroughs author page on
                    Project Gutenberg</a>
                  (full bibliography)
                </li>
                <li>
                  <a
                    href="https://onlinebooks.library.upenn.edu/webbin/book/lookupname?key=Burroughs%2C+John%2C+1837-1921"
                    target="_blank"
                    rel="noopener noreferrer">Online Books Page (UPenn) author
                    index</a>
                </li>
              </ul>
            </li>
          </ul>

          <h4 id="mabel-osgood-wright">Mabel Osgood Wright (1859&ndash;1934)</h4>
          <img class="author-icon" src="/images/library/authors/mabel-osgood-wright-icon.jpg" alt="Mabel Osgood Wright portrait" width="96" height="96" loading="lazy" />
          <p>
            Connecticut-based but New York-published. Beginning in 1884, wrote
            nature essays anonymously for the <em>New York Times</em> and the
            <em>Evening Post</em>. Co-founded the Connecticut Audubon Society
            in 1898. Opened Birdcraft Sanctuary in Fairfield, Connecticut, on
            October 16, 1914: the first private songbird sanctuary in the
            United States. Birdcraft was later listed on the National Register
            of Historic Places (1982) and designated a National Historic
            Landmark (1993).
          </p>
          <ul class="library-titles">
            <li>
              <em>Birdcraft: A Field Book of Two Hundred Song, Game, and Water
              Birds</em> (1895, Macmillan). A prototype of the modern popular
              field guide. Featured color plates from Audubon and others;
              later editions added illustrations by Louis Agassiz Fuertes.
              Reprinted nine times between 1895 and 1936; the most popular
              American bird guide before Roger Tory Peterson's <em>Field Guide
              to the Birds</em> (1934).
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/birdcraftfieldbo01wrig"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (1st edition)</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/birdcraft00wrig"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (alt scan)</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/birdcraftafield04wriggoog"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive
                    (Google/Smithsonian scan)</a>
                </li>
                <li>
                  <a
                    href="https://www.biodiversitylibrary.org/bibliography/13260"
                    target="_blank"
                    rel="noopener noreferrer">Biodiversity Heritage Library</a>
                </li>
              </ul>
            </li>
            <li>
              <em>The Making of Birdcraft Sanctuary</em>. Memoir of building
              the sanctuary.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/cu31924090201306"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
              </ul>
            </li>
          </ul>

          <h4 id="witmer-stone">Witmer Stone (1866&ndash;1939)</h4>
          <img class="author-icon" src="/images/library/authors/witmer-stone-icon.jpg" alt="Witmer Stone portrait" width="96" height="96" loading="lazy" />
          <p>
            Philadelphia-based naturalist at the Academy of Natural
            Sciences. His fieldwork on the New Jersey coast made him the
            definitive ornithological voice on Cape May and broader NJ.
            Editor of <em>The Auk</em> for roughly 25 years (approximately
            1912&ndash;1936). Pre-1929 work is public domain; his
            masterwork <em>Bird Studies at Old Cape May</em> (1937) is
            <strong>not yet PD</strong> under the 95-year rule (enters PD
            Jan 1, 2033).
          </p>
          <ul class="library-titles">
            <li>
              <em>The Birds of New Jersey</em> (1908). Comprehensive state
              survey, published as part of the New Jersey State Museum
              Annual Report. The most important pre-1929 reference on NJ
              ornithology.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/birdsofnewjersey00stonrich"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
                <li>
                  <a
                    href="https://www.biodiversitylibrary.org/bibliography/29952"
                    target="_blank"
                    rel="noopener noreferrer">Biodiversity Heritage Library</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Annual Report of the New Jersey State Museum,
              1901&ndash;1912, 1914</em> (containing his bird and mammal
              surveys).
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/annualreportofne00newj"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Bird Studies at Old Cape May</em> (1937). His masterwork,
              the definitive treatment of Cape May ornithology.
              <strong>Not yet public domain</strong> (enters PD Jan 1,
              2033).
            </li>
            <li>
              His pre-1929 articles in <em>The Auk</em> (where he was
              editor), <em>Bird-Lore</em>, and <em>Cassinia</em> (journal
              of the Delaware Valley Ornithological Club) are public
              domain. Available via SORA and BHL.
            </li>
            <li>
              Author master indexes:
              <a
                href="https://www.biodiversitylibrary.org/creator/1413"
                target="_blank"
                rel="noopener noreferrer">Biodiversity Heritage Library
                creator page</a>,
              <a
                href="https://en.wikipedia.org/wiki/Witmer_Stone"
                target="_blank"
                rel="noopener noreferrer">Wikipedia article</a>.
            </li>
          </ul>

          <h3>Women in birdwatching</h3>

          <h4 id="florence-merriam-bailey"><a href="/notes/florence-merriam-bailey/">Florence Merriam Bailey</a> (1863&ndash;1948)</h4>
          <img class="author-icon" src="/images/library/authors/florence-merriam-bailey-icon.jpg" alt="Florence Merriam Bailey portrait" width="96" height="96" loading="lazy" />
          <p>
            Inventor of modern birdwatching. Wrote <em>Birds Through an Opera
            Glass</em> (1889), the first illustrated American field guide for
            non-scientists. Founded the Smith College Audubon chapter in 1886.
            First female associate member of the AOU (1885), first woman
            elected Fellow (1929), first woman to receive the Brewster Medal
            (1931, for <em>Birds of New Mexico</em>).
          </p>
          <ul class="library-titles">
            <li>
              <em>Birds Through an Opera Glass</em> (1889). The first
              illustrated American field guide for non-scientists. The founding
              text.
              <ul>
                <li>
                  <a
                    href="https://archive.org/details/birdsthroughopera00bailrich"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (first
                    edition)</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/birdsthroughano00bailgoog"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive (Harvard scan)</a>
                </li>
                <li>
                  <a
                    href="https://catalog.hathitrust.org/Record/001501418"
                    target="_blank"
                    rel="noopener noreferrer">HathiTrust catalog</a>
                </li>
                <li>
                  <a
                    href="https://catalog.hathitrust.org/Record/009262054"
                    target="_blank"
                    rel="noopener noreferrer">HathiTrust (alt edition)</a>
                </li>
              </ul>
            </li>
            <li>
              <em>A-Birding on a Bronco</em> (1896). Field memoir of
              birdwatching in California in the late 1880s, riding her white
              horse Canello. Illustrated by Louis Agassiz Fuertes, then a
              student at Cornell; this was Fuertes's first published work.
              <ul>
                <li>
                  <a
                    href="https://www.gutenberg.org/files/33410/33410-h/33410-h.htm"
                    target="_blank"
                    rel="noopener noreferrer">Project Gutenberg HTML</a>
                </li>
                <li>
                  <a
                    href="https://catalog.hathitrust.org/Search/Home?lookfor=A-Birding+on+a+Bronco"
                    target="_blank"
                    rel="noopener noreferrer">HathiTrust catalog search</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Birds of Village and Field: A Bird Book for Beginners</em>
              (1898). Reprinted articles, with simple field color-keys for
              identification. Over 200 drawings by Ernest Thompson Seton,
              Louis Agassiz Fuertes, and John L. Ridgway.
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=birds+of+village+and+field+bailey"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
                <li>
                  <a
                    href="https://catalog.hathitrust.org/Search/Home?lookfor=Birds+of+Village+and+Field+Bailey"
                    target="_blank"
                    rel="noopener noreferrer">HathiTrust search</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Handbook of Birds of the Western United States</em> (1902).
              Companion volume to Frank M. Chapman's <em>Handbook of Birds of
              Eastern North America</em> (1895). Standard regional reference
              for decades.
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=handbook+birds+western+united+states+bailey"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
                <li>
                  <a
                    href="https://catalog.hathitrust.org/Search/Home?lookfor=Handbook+Birds+Western+United+States+Bailey"
                    target="_blank"
                    rel="noopener noreferrer">HathiTrust search</a>
                </li>
              </ul>
            </li>
            <li>
              <em>Birds of New Mexico</em> (1928). The monograph that won her
              the Brewster Medal in 1931.
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=birds+of+new+mexico+bailey"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
              </ul>
            </li>
            <li>
              Author master index:
              <a
                href="https://onlinebooks.library.upenn.edu/webbin/book/lookupname?key=Bailey,+Florence+Merriam,+1863-1948"
                target="_blank"
                rel="noopener noreferrer">Online Books Page (UPenn)</a>.
            </li>
          </ul>

          <h4>Mabel Osgood Wright (1859&ndash;1934)</h4>
          <p>
            See Mabel Osgood Wright above under <a href="#nyc-and-the-metro-region">NYC
            and the metro region</a> for her full entry and download links.
          </p>

          <h4 id="olive-thorne-miller">Olive Thorne Miller (1831&ndash;1918)</h4>
          <img class="author-icon" src="/images/library/authors/olive-thorne-miller-icon.jpg" alt="Olive Thorne Miller portrait" width="96" height="96" loading="lazy" />
          <p>
            Pen name of Harriet Mann Miller. Adopted "Olive Thorne" early for
            letters and articles, then added her married name as the
            pseudonym became established. Took up serious bird study in 1880
            at age 49, introduced to it by Sara A. Hubbard, director of the
            Illinois Audubon Society. Wrote 11 bird-related books and
            approximately 780 articles across her career. One of the first
            three women elected to membership in the American Ornithologists'
            Union.
          </p>
          <ul class="library-titles">
            <li>
              <em>Bird-Ways</em> (1885).
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=bird-ways+olive+thorne+miller"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
              </ul>
            </li>
            <li>
              <em>In Nesting Time</em> (1888).
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=in+nesting+time+olive+thorne+miller"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
              </ul>
            </li>
            <li>
              <em>A Bird-Lover in the West</em> (1894).
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=bird-lover+in+the+west+olive+thorne+miller"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive search</a>
                </li>
              </ul>
            </li>
            <li>
              Several others (<em>True Bird Stories from My Note-Books</em>,
              <em>Little Brothers of the Air</em>, <em>The Children's Book of
              Birds</em>, <em>The Second Book of Birds: Bird Families</em>),
              all public domain.
              <ul>
                <li>
                  <a
                    href="https://archive.org/search.php?query=creator%3A%22Olive+Thorne+Miller%22"
                    target="_blank"
                    rel="noopener noreferrer">Internet Archive: Olive Thorne
                    Miller bibliography</a>
                </li>
              </ul>
            </li>
          </ul>

          <h4 id="neltje-blanchan">Neltje Blanchan (1865&ndash;1918)</h4>
          <img class="author-icon" src="/images/library/authors/neltje-blanchan-icon.jpg" alt="Neltje Blanchan portrait" width="96" height="96" loading="lazy" />
          <p>
            Real name Nellie Blanchan De Graff Doubleday, married to publisher
            Frank Doubleday, which gave her unusual access to publication.
            Plain prose, vivid observation. Widely read in the early 20th
            century.
          </p>
          <ul class="library-titles">
            <li>
              <em>Bird Neighbors</em> (1897).
              <ul>
                <li>
                  <a
                    href="https://www.gutenberg.org/ebooks/37735"
                    target="_blank"
                    rel="noopener noreferrer">Project Gutenberg eBook</a>
                </li>
                <li>
                  <a
                    href="https://www.gutenberg.org/files/37735/37735-h/37735-h.htm"
                    target="_blank"
                    rel="noopener noreferrer">Project Gutenberg HTML</a>
                </li>
                <li>
                  <a
                    href="https://archive.org/details/birdneighbor00blan"
