---
import "../styles/global.css";

const title = "Shelly Xiong — Links";
const description =
  "Links, projects, and socials for Shelly Xiong. NYC birder, illustrator, and developer.";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />

    <meta property="og:title" content="Shelly Xiong — NYC birder, illustrator, and developer" />
    <meta property="og:description" content="Documenting the birds of New York City's five boroughs." />
    <meta property="og:image" content="https://shellylynnx.com/images/shelly-avatar.jpg" />
    <meta property="og:url" content="https://shellylynnx.com/links" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://shellylynnx.com/images/shelly-avatar.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <button class="links-theme" id="theme-toggle" aria-label="Toggle light/dark mode">
      <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <main class="links-page">
      <img
        class="links-avatar"
        src="/images/shelly-avatar.jpg"
        alt="Shelly Xiong"
        width="140"
        height="140"
      />
      <h1 class="links-name">Shelly Xiong</h1>
      <p class="links-handle">@shellylynnx</p>
      <p class="links-headline">
        NYC birder, illustrator, and developer documenting New York's birds across the five boroughs.
      </p>

      <div class="link-stack">
        <a class="link-card" href="https://shellylynnx.com">
          <span>shellylynnx.com</span>
          <span class="link-arrow">→</span>
        </a>
        <a class="link-card" href="https://shellylynnx.com/newsletter">
          <span>Monthly newsletter</span>
          <span class="link-arrow">→</span>
        </a>
        <a class="link-card" href="https://shellylynnx.com/about">
          <span>About</span>
          <span class="link-arrow">→</span>
        </a>
        <a
          class="link-card"
          href="https://shellylynnx.github.io/projects/METBird/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>METBird — Met Museum bird artworks</span>
          <span class="link-arrow">↗</span>
        </a>
        <a
          class="link-card"
          href="https://shellylynnx.github.io/projects/NYCoffleash/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>NYC Off-Leash map</span>
          <span class="link-arrow">↗</span>
        </a>
      </div>

      <div class="link-socials">
        <a class="link-social" href="mailto:helloshellylynnx@gmail.com" aria-label="Email">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a class="link-social" href="https://www.tiktok.com/@shellylynnx" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
        <a class="link-social" href="https://www.instagram.com/shellylynnx/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.882 0 1.441 1.441 0 012.882 0z"/></svg>
        </a>
        <a class="link-social" href="https://ebird.org/profile/NDQ0MjU4OA" target="_blank" rel="noopener noreferrer" aria-label="eBird">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
        </a>
        <a class="link-social" href="https://github.com/shellylynnx" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0.297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.084-.73.084-.73 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
      </div>

      <p class="links-footer">🐦‍⬛ shellylynnx.com</p>
    </main>

    <style>
      body {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 32px 20px 48px;
      }

      .links-theme {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 10;
        background: none;
        border: 1px solid var(--color-border);
        border-radius: 4px;
        cursor: pointer;
        padding: 6px 8px;
        color: var(--color-text);
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          border-color 0.2s,
          color 0.2s;
      }

      .links-theme:hover {
        border-color: var(--color-secondary);
        color: var(--color-secondary);
      }

      .links-page {
        width: 100%;
        max-width: 440px;
        text-align: center;
        padding-top: 8px;
      }

      .links-avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--color-border);
        display: block;
        margin: 0 auto 20px;
      }

      .links-name {
        font-family: var(--font-display);
        font-size: 2rem;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 4px;
        line-height: 1.15;
      }

      .links-handle {
        font-size: 0.9375rem;
        color: var(--color-secondary);
        letter-spacing: 0.04em;
        margin-bottom: 12px;
      }

      .links-headline {
        font-size: 0.9375rem;
        color: var(--color-text-secondary);
        line-height: 1.55;
        margin: 0 auto 28px;
        max-width: 380px;
      }

      .link-stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 24px;
      }

      .link-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        background: var(--color-card-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        color: var(--color-text);
        font-size: 0.9375rem;
        font-weight: 500;
        text-align: left;
        text-decoration: none;
        transition:
          transform 0.15s ease,
          border-color 0.2s,
          color 0.2s,
          box-shadow 0.2s;
      }

      .link-card:hover {
        color: var(--color-secondary);
        border-color: var(--color-secondary);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
      }

      body.light .link-card:hover {
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
      }

      .link-arrow {
        flex: 0 0 auto;
        color: var(--color-text-dim);
        font-size: 1rem;
      }

      .link-card:hover .link-arrow {
        color: var(--color-secondary);
      }

      .link-socials {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 32px;
        flex-wrap: wrap;
      }

      .link-social {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: 1px solid var(--color-border);
        border-radius: 50%;
        color: var(--color-text);
        background: var(--color-card-bg);
        transition:
          border-color 0.2s,
          color 0.2s,
          background 0.2s;
      }

      .link-social svg {
        opacity: 0.85;
        transition: opacity 0.2s;
      }

      .link-social:hover {
        border-color: var(--color-secondary);
        color: var(--color-secondary);
      }

      .link-social:hover svg {
        opacity: 1;
      }

      .links-footer {
        font-size: 0.8125rem;
        color: var(--color-text-dim);
        margin: 0;
      }
    </style>

    <script is:inline>
      (function () {
        if (localStorage.getItem("theme") === "light") {
          document.body.classList.add("light");
        }
        const themeToggle = document.getElementById("theme-toggle");
        themeToggle.addEventListener("click", function () {
          document.body.classList.toggle("light");
          localStorage.setItem(
            "theme",
            document.body.classList.contains("light") ? "light" : "dark",
          );
        });
      })();
    </script>
  </body>
</html>
