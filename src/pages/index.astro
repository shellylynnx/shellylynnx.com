---
import BaseLayout from "../layouts/BaseLayout.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
---

<BaseLayout title="Shelly Xiong — NYC birder, artist, and developer">
  <header class="hero" id="hero">
    <div class="hero-content">
      <p class="hero-greeting">Hello, I'm</p>
      <h1 class="hero-name">Shelly Xiong</h1>
      <img class="hero-avatar" src="/images/shelly-avatar.jpg" alt="Shelly Xiong" width="120" height="120" />
      <p class="hero-persona">NYC Subway Birder</p>
      <p class="hero-handle"><a href="#contact">@shellylynnx</a></p>
      <p class="hero-tagline">
        NYC birder, artist, and developer documenting New York's birds across the five boroughs.
      </p>
      <p class="hero-description">
        Field notes, art, and small tools for the city's birds.
      </p>
      <div class="hero-actions">
        <a href="/notes" class="btn btn-outline">Notes</a>
        <a href="/tools" class="btn btn-outline">Tools</a>
        <a href="/about" class="btn btn-outline">About</a>
        <a href="/newsletter" class="btn btn-primary">Newsletter</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </header>

  <main>
    <section class="section working-on" id="working-on">
      <div class="container">
        <h2 class="section-title">What I'm working on</h2>
        <div class="about-grid" style="grid-template-columns: repeat(3, 1fr); gap: 40px;">
          <div>
            <h3 style="font-family: var(--font-display); font-size: 1.125rem; margin-bottom: 12px; color: var(--color-text);">Field notes</h3>
            <p style="color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.6;">
              Dispatches from NYC's parks, shores, and fire escapes. A species I met. A spot I tried. A thing the birds taught me about the city.
            </p>
          </div>
          <div>
            <h3 style="font-family: var(--font-display); font-size: 1.125rem; margin-bottom: 12px; color: var(--color-text);">Tools</h3>
            <p style="color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.6;">
              Small pieces of software for birders, built out of curiosity. METBird, NYC Off-Leash, whatever else is next. Open source. Use them however.
            </p>
          </div>
          <div>
            <h3 style="font-family: var(--font-display); font-size: 1.125rem; margin-bottom: 12px; color: var(--color-text);">Art</h3>
            <p style="color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.6;">
              Photographs, illustrations, risograph, and archival prints.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section projects" id="projects">
      <div class="container">
        <h2 class="section-title">Tools &amp; projects</h2>
        <div class="project-grid">
          <a href="https://shellylynnx.github.io/projects/METBird/" class="project-card-link" target="_blank" rel="noopener noreferrer">
            <article class="project-card">
              <div class="project-color" style="background: #ec012a;"></div>
              <div class="project-info">
                <h3>METBird</h3>
                <p>A searchable browser for the Met Museum's 9,751 open-access bird artworks, cross-referenced with eBird taxonomy.</p>
                <div class="project-tags">
                  <span>Met Open Access</span>
                  <span>eBird taxonomy</span>
                  <span>Browse UI</span>
                </div>
              </div>
            </article>
          </a>
          <a href="https://shellylynnx.github.io/projects/NYCoffleash/" class="project-card-link" target="_blank" rel="noopener noreferrer">
            <article class="project-card">
              <div class="project-color" style="background: #3a7d44;"></div>
              <div class="project-info">
                <h3>NYC Off-Leash</h3>
                <p>Interactive map for NYC dog runs, off-leash areas, and animal incident reports. Built with MapLibre GL and NYC Open Data.</p>
                <div class="project-tags">
                  <span>MapLibre GL</span>
                  <span>NYC Open Data</span>
                  <span>Map UI</span>
                </div>
              </div>
            </article>
          </a>
          <a href="https://shellylynnx.github.io/projects/riso-preview/" class="project-card-link" target="_blank" rel="noopener noreferrer">
            <article class="project-card">
              <div class="project-color" style="background: linear-gradient(135deg, #e8c547, #d4775c, #5a8fbb);"></div>
              <div class="project-info">
                <h3>Riso Preview</h3>
                <p>A risograph print simulator that previews artwork in riso ink colors with 3-layer overprint blending.</p>
                <div class="project-tags">
                  <span>Canvas API</span>
                  <span>Print design</span>
                  <span>Color theory</span>
                </div>
              </div>
            </article>
          </a>
          <a href="https://shellylynnx.github.io/projects/one-page-zine/" class="project-card-link" target="_blank" rel="noopener noreferrer">
            <article class="project-card">
              <div class="project-color" style="background: #AEB784;"></div>
              <div class="project-info">
                <h3>One-Page Zine</h3>
                <p>Layout tool for making 8-page zines from a single sheet, with PDF and image export.</p>
                <div class="project-tags">
                  <span>jsPDF</span>
                  <span>Print layout</span>
                  <span>Zine making</span>
                </div>
              </div>
            </article>
          </a>
        </div>
      </div>
    </section>

    <section class="section newsletter-block" id="newsletter-block">
      <div class="container">
        <h2 class="section-title">Field Notes, once a month</h2>
        <p style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 24px; max-width: 640px;">
          One NYC species. One field observation. One link worth clicking. Plus: first access to new art, tools, and zine drops. Free.
        </p>
        <SubscribeForm buttonLabel="Send me the birds" />
        <p style="margin-top: 16px;"><a href="/newsletter" style="font-size: 0.875rem;">See the full newsletter page →</a></p>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div class="container">
        <h2 class="section-title">Connect</h2>
        <p class="contact-intro">Interested in collaborating or just want to say hello?</p>
        <div class="social-links">
          <a href="mailto:helloshellylynnx@gmail.com" class="social-link">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </a>
          <a href="https://www.tiktok.com/@shellylynnx" class="social-link" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            TikTok
          </a>
          <a href="https://www.instagram.com/shellylynnx/" class="social-link" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.882 0 1.441 1.441 0 012.882 0z"/></svg>
