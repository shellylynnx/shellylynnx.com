---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Newsletter — Shelly Xiong"
  description="A monthly dispatch on NYC birds, illustrations, and small software tools. Free. By Shelly Xiong."
>
  <main style="padding-top: calc(var(--nav-height) + 40px);">
    <section class="section newsletter" id="newsletter">
      <div class="container" style="max-width: 720px;">
        <h2 class="section-title">A bird in your inbox, once a month.</h2>
        <p style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 16px;">
          Once a month, one short dispatch about the birds of New York City. What I'm seeing in the park, which warblers are moving through, what I drew, what I built, what I read.
        </p>
        <p style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 32px;">
          No ads, no sponsors (at least not yet). Archived at <a href="/">shellylynnx.com</a>.
        </p>

        <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
        <iframe src="https://subscribe-forms.beehiiv.com/2f636490-db99-422f-953c-0fd1bc2a864f" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 560px; height: 291px; margin: 0; border-radius: 0px 0px 0px 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>
      </div>
    </section>
  </main>
</BaseLayout>
