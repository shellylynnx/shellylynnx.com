---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Image Credits | The Public Domain Bird Library";
const description =
  "Source URLs and licensing for the 11 author portrait icons used on shellylynnx.com/library/. All portraits are pre-1929 U.S. works in the public domain.";
const canonical = new URL("/library/image-credits/", Astro.site).href;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogTitle="Image Credits | The Public Domain Bird Library"
  ogDescription={description}
  ogType="article"
>
  <main style="padding-top: var(--nav-height);">
    <section class="section image-credits-page" id="image-credits">
      <div class="container" style="max-width: 720px;">
        <h2 class="section-title">Image Credits</h2>
        <p class="section-dek">
          Attribution and licensing for the 11 portrait icons used on
          <a href="/library/">The Public Domain Bird Library</a>. All
          portraits are pre-1929 U.S. works and unambiguously in the public
          domain under the 95-year rule.
        </p>

        <div class="library-body">
          <p><em>Last updated: April 26, 2026.</em></p>

          <h3>License posture (applies to all entries)</h3>
          <p>
            Every portrait below was published before 1929 in the United
            States, putting each unambiguously in the public domain. No
            permissions or payments are required for use. Attribution is
            provided as a courtesy to readers and to the institutional
            sources that host the scans, not as a legal obligation.
          </p>
          <p>
            For the underlying legal reference, see the
            <a
              href="https://copyright.cornell.edu/publicdomain"
              target="_blank"
              rel="noopener noreferrer">Cornell Copyright Term and Public
              Domain chart</a>.
          </p>

          <h3>NYC and the metro region</h3>

          <h4>Frank M. Chapman (1864&ndash;1945)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:Portrait_of_Frank_Chapman.jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:Portrait_of_Frank_Chapman.jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from <em>The World's Work</em> magazine via Internet Archive)</li>
            <li><strong>Original date:</strong> No later than 1913</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h4>C. Hart Merriam (1855&ndash;1942)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:Clinton_Hart_Merriam_cph.3b44758.jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:Clinton_Hart_Merriam_cph.3b44758.jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (filename suffix <code>cph.3b44758</code> indicates Library of Congress Prints &amp; Photographs Division origin)</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h4>John Burroughs (1837&ndash;1921)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:Photo_of_John.Burroughs.jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:Photo_of_John.Burroughs.jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929; Burroughs died 1921)</li>
          </ul>

          <h4>Mabel Osgood Wright (1859&ndash;1934)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:Mabel_Osgood_Wright_Bird-Lore-v15-crop.jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:Mabel_Osgood_Wright_Bird-Lore-v15-crop.jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from <em>Bird-Lore</em> magazine, volume 15)</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h4>Witmer Stone (1866&ndash;1939)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:WitmerStone.jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:WitmerStone.jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from <em>Bird-Lore</em> magazine)</li>
            <li><strong>Original date:</strong> 1916</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h3>Women in birdwatching</h3>

          <h4>Florence Merriam Bailey (1863&ndash;1948)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:FlorenceMerriam1904.jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:FlorenceMerriam1904.jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from <em>The Condor: A Magazine of Western Ornithology</em>, Vol. 6, No. 5, September&ndash;October 1904; SORA archive at University of New Mexico)</li>
            <li><strong>Original date:</strong> 1904</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (pd-old; U.S. work published before 1929)</li>
          </ul>

          <h4>Olive Thorne Miller / Harriet Mann Miller (1831&ndash;1918)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:OLIVE_THORNE_MILLER_A_woman_of_the_century_(page_517_crop).jpg" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:OLIVE_THORNE_MILLER_A_woman_of_the_century_(page_517_crop).jpg</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from <em>A Woman of the Century</em>, page 517, an 1893 biographical encyclopedia of American women edited by Frances E. Willard and Mary A. Livermore)</li>
            <li><strong>Original date:</strong> 1893</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h4>Neltje Blanchan / Nellie Doubleday (1865&ndash;1918)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://www.findagrave.com/memorial/23523361/neltje-blanchan-doubleday" target="_blank" rel="noopener noreferrer">Find a Grave memorial 23523361</a>
            </li>
            <li><strong>Source institution:</strong> Find a Grave (re-hosting a pre-1918 original; original photographer unknown)</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929; Neltje died in 1918)</li>
          </ul>

          <h4>Cordelia Stanwood (1865&ndash;1958)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:Stanwood1900.png" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:Stanwood1900.png</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from <a href="http://judelamb.com/cordelia-j-stanwood/" target="_blank" rel="noopener noreferrer">judelamb.com/cordelia-j-stanwood/</a>)</li>
            <li><strong>Original date:</strong> 1900 (Stanwood at age 35)</li>
            <li><strong>Author:</strong> Unknown photographer</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h4>Althea Sherman (1853&ndash;1943)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/File:Althea_Sherman_1875.png" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/File:Althea_Sherman_1875.png</a>
            </li>
            <li><strong>Source institution:</strong> Wikimedia Commons (originally from
              <a href="https://biodiversitylibrary.org/page/51704503" target="_blank" rel="noopener noreferrer">Biodiversity Heritage Library</a>)
            </li>
            <li><strong>Original date:</strong> Circa 1875 (Sherman as a student at Oberlin College, age ~22)</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (U.S. work published before 1929)</li>
          </ul>

          <h4>Margaret Morse Nice (1883&ndash;1974)</h4>
          <ul class="credits-list">
            <li><strong>Source URL:</strong>
              <a href="https://commons.wikimedia.org/wiki/Category:Margaret_Morse_Nice" target="_blank" rel="noopener noreferrer">commons.wikimedia.org/wiki/Category:Margaret_Morse_Nice</a>
              (the only file in the category is hosted under a Hebrew filename; Wikipedia's article uses the English-Wikipedia upload)
            </li>
            <li><strong>Source institution:</strong> Wikipedia / Wikimedia Commons</li>
            <li><strong>Author:</strong> Unknown</li>
            <li><strong>License:</strong> Public domain (this specific portrait pre-1929)</li>
          </ul>

          <hr />

          <p class="library-meta">
            <a href="/library/">&larr; Back to The Public Domain Bird
            Library</a>
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .library-body {
    color: var(--color-text);
    line-height: 1.7;
  }

  .library-body p {
    margin-bottom: 16px;
  }

  .library-body h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 48px;
    margin-bottom: 16px;
    color: var(--color-text);
  }

  .library-body h4 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 28px;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .library-body a {
    color: var(--color-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .library-body a:hover {
    color: var(--color-highlight);
  }

  .credits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
  }

  .credits-list li {
    margin-bottom: 6px;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    word-break: break-word;
  }

  .credits-list code {
    font-size: 0.8125rem;
    background: var(--color-card-bg);
    padding: 2px 4px;
    border-radius: 3px;
  }

  .library-body hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0 16px;
  }

  .library-meta {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    font-style: italic;
    margin-top: 24px;
  }
</style>
