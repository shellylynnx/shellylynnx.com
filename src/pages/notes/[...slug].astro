---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const notes = await getCollection("notes", ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
};

const { note } = Astro.props;
const { Content } = await render(note);
const { data } = note;

const escHtml = (s: string) =>
  s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");

const escScript = (s: string) => s.replace(/</g, "\\u003c");

const canonical =
  data.canonicalURL ?? new URL(`/notes/${note.id}/`, Astro.site).href;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });

const ogImageUrl = data.ogImage
  ? new URL(data.ogImage, Astro.site).href
  : new URL("/images/shelly-avatar.jpg", Astro.site).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    "@id": "https://shellylynnx.com/#shelly",
    name: "Shelly Lynn Xiong",
    alternateName: ["Shelly Lynn", "Shelly Xiong", "NYC Subway Birder", "shellylynnx"],
    url: "https://shellylynnx.com",
    worksFor: {
      "@type": "Organization",
      name: "The Metropolitan Museum of Art",
      url: "https://www.metmuseum.org",
    },
    sameAs: [
      "https://shellylynnx.com",
      "https://www.tiktok.com/@shellylynnx",
      "https://www.instagram.com/shellylynnx/",
      "https://github.com/shellylynnx",
      "https://ebird.org/profile/NDQ0MjU4OA",
    ],
  },
  publisher: {
    "@type": "Organization",
    name: "Shelly Lynn Xiong",
    logo: {
      "@type": "ImageObject",
      url: "https://shellylynnx.com/favicon.svg",
    },
  },
  image: ogImageUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  keywords: data.tags.join(", "),
  articleSection: data.category,
  ...(data.references.length > 0 && {
    citation: data.references.map((r) => r.url),
  }),
};

const wordCount = note.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readTime = Math.max(1, Math.round(wordCount / 220));
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonical={canonical}
  ogTitle={data.title}
  ogDescription={data.description}
  ogImage={data.ogImage}
  ogImageAlt={data.ogImageAlt}
  ogType="article"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={escScript(JSON.stringify(articleSchema))}
  />

  <script is:inline>
    (function () {
      function openRefsFor(hash) {
        if (!hash || !hash.startsWith("#ref-")) return;
        var refs = document.querySelector(".note-refs");
        if (refs && !refs.open) refs.open = true;
        requestAnimationFrame(function () {
          var target = document.querySelector(hash);
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      }
      document.addEventListener("click", function (e) {
        var a = e.target.closest && e.target.closest("a.note-cite-link");
        if (!a) return;
        e.preventDefault();
        var hash = new URL(a.href).hash;
        if (history.replaceState) history.replaceState(null, "", hash);
        openRefsFor(hash);
      });
      if (window.location.hash) openRefsFor(window.location.hash);
    })();
  </script>

  <main style="padding-top: var(--nav-height);">
    <article class="note-article">
      <div class="container" style="max-width: 720px;">
        <header class="note-header">
          <p class="note-byline">
            <a href="/notes" class="note-back">← Notes</a>
          </p>
          <h1 class="note-title">{data.title}</h1>
          <p class="note-dek">{data.description}</p>
          <p class="note-meta">
            <span>{fmt(data.pubDate)}</span>
            <span class="note-meta-dot">·</span>
            <span>{data.author}</span>
            <span class="note-meta-dot">·</span>
            <span>{readTime} min read</span>
            <span class="note-meta-dot">·</span>
            <span>{data.category}</span>
          </p>
        </header>

        {
          data.ogImage && (
            <figure class="note-hero-figure">
              <img class="note-hero-image" src={data.ogImage} alt={data.title} loading="eager" />
            </figure>
          )
        }

        <div class="note-body">
          <Content />
        </div>

        <AuthorBio topics={data.topics} />

        {
          data.birdsMentioned.length > 0 && (
            <section class="note-birds" aria-labelledby="birds-mentioned">
              <h2 id="birds-mentioned" class="note-section-heading">
                Birds Mentioned
              </h2>
              <ul class="note-birds-list">
                {data.birdsMentioned.map((bird) => (
                  <li>
                    <a
                      href={`https://ebird.org/species/${bird.ebirdCode}`}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {bird.commonName}
                    </a>
                    {bird.note && <span class="note-birds-note">, {bird.note}</span>}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          data.subwayRoutes.length > 0 && (
            <section class="note-subway" aria-labelledby="subway-routes">
              <h2 id="subway-routes" class="note-section-heading">
                Subway Routes
              </h2>
              <details class="note-refs note-subway-routes">
                <summary>Show routes ({data.subwayRoutes.length})</summary>
                <ul class="note-subway-routes-list">
                  {data.subwayRoutes.map((route) => {
                    const modeParts = [];
                    if (route.lines.length > 0) {
                      const linesText = route.lines.map(escHtml).join(" / ");
                      modeParts.push(
                        `<span class="note-subway-mode"> · ${linesText} train${route.lines.length > 1 ? "s" : ""}</span>`,
                      );
                    }
                    if (route.lirr) {
                      modeParts.push(
                        `<span class="note-subway-mode"> · LIRR ${escHtml(route.lirr)}</span>`,
                      );
                    }
                    if (route.buses && route.buses.length > 0) {
                      const busesText = route.buses.map(escHtml).join(", ");
                      modeParts.push(
                        `<span class="note-subway-mode"> · bus: ${busesText}</span>`,
                      );
                    }
                    const html = `<strong>${escHtml(route.hotspot)}</strong>${modeParts.join("")}<span class="note-subway-directions">. ${escHtml(route.directions)}</span>`;
                    return <li set:html={html} />;
                  })}
                </ul>
              </details>
            </section>
          )
        }

        {
          data.photoCredits && (
            <section class="note-photo-credits" aria-labelledby="credits">
              <h2 id="credits" class="note-section-heading">
                Credits
              </h2>
              <p set:html={data.photoCredits} />
            </section>
          )
        }

        {
          data.references.length > 0 && (
            <details class="note-refs">
              <summary>References ({data.references.length})</summary>
              <ol class="note-refs-list">
                {data.references.map((ref, i) => {
                  const refNumber = ref.number ?? i + 1;
                  const parts = [];
                  if (ref.author) parts.push(`${escHtml(ref.author)}. `);
                  parts.push(
                    ref.url
                      ? `<a href="${escHtml(ref.url)}" target="_blank" rel="noopener noreferrer">${escHtml(ref.title)}</a>`
                      : `<span>${escHtml(ref.title)}</span>`,
                  );
                  if (ref.publication) parts.push(`, ${escHtml(ref.publication)}`);
                  if (ref.date) parts.push(`, ${escHtml(ref.date)}`);
                  if (ref.note) parts.push(`. ${escHtml(ref.note)}`);
                  return (
                    <li id={`ref-${refNumber}`} value={refNumber} set:html={parts.join("")} />
                  );
                })}
              </ol>
            </details>
          )
        }
      </div>
    </article>
  </main>
</BaseLayout>
