---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SubscribeForm from "../../components/SubscribeForm.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { getCollection } from "astro:content";

const TAG = "subway-birder";

const allNotes = await getCollection("notes", ({ data }) => !data.draft);

const columnNotes = allNotes
  .filter((n) => (n.data.tags ?? []).includes(TAG))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });

const canonical = "https://shellylynnx.com/notes/subway-birder";
const heroImage = "/images/notes/subway-birder/rocpig-643158959-cropped.jpg";
const ogImage = `https://shellylynnx.com${heroImage}`;

const title = "The Subway Birder | NYC birding, one train line at a time";
const description =
  "A recurring column by Shelly Lynn Xiong on birding New York City by subway. Field logs, hotspots, and timing, all reachable by train.";

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "The Subway Birder",
  headline: "The Subway Birder — NYC birding, one train line at a time",
  description,
  url: canonical,
  inLanguage: "en-US",
  isPartOf: {
    "@type": "WebSite",
    name: "shellylynnx.com",
    url: "https://shellylynnx.com",
  },
  about: {
    "@type": "Thing",
    name: "Subway Birder",
    description:
      "A person who birds New York City using the MTA subway system rather than a car.",
  },
  author: {
    "@type": "Person",
    "@id": "https://shellylynnx.com/#shelly",
    name: "Shelly Lynn Xiong",
    alternateName: [
      "Shelly Lynn",
      "Shelly Xiong",
      "The Subway Birder",
      "NYC Subway Birder",
    ],
    url: "https://shellylynnx.com/about",
    sameAs: [
      "https://www.instagram.com/shellylynnx",
      "https://www.tiktok.com/@shellylynnx",
      "https://ebird.org/profile/NDQ0MjU4OA",
      "https://www.reddit.com/user/subwaybirder/",
    ],
  },
  hasPart: columnNotes.map((n) => ({
    "@type": "Article",
    headline: n.data.title,
    url: `https://shellylynnx.com/notes/${n.id}/`,
    datePublished: n.data.pubDate.toISOString(),
  })),
  mainEntity: {
    "@type": "DefinedTerm",
    name: "Subway Birder",
    description:
      "A New York City birder who uses the MTA subway system as their primary means of accessing birding patches across the five boroughs.",
    inDefinedTermSet: canonical,
  },
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(collectionSchema).replace(/</g, "\\u003c")}
  />

  <main style="padding-top: var(--nav-height);">
    <section class="section subway-birder-hero">
      <div class="container" style="max-width: 880px;">
        <figure class="subway-hero-figure">
          <img
            class="subway-hero-image"
            src={heroImage}
            alt="A Rock Pigeon on a New York City sidewalk, crumb of bread just out of reach."
            loading="eager"
          />
          <figcaption>Rock Pigeon, NYC. Photo © Shelly Xiong / Macaulay Library.</figcaption>
        </figure>
        <h1 class="subway-hero-title">The Subway Birder</h1>
        <p class="subway-hero-dek">NYC birding, one train line at a time.</p>
        <p class="subway-hero-byline">
          By <a href="/about">Shelly Xiong</a>. A recurring column on
          shellylynnx.com.
        </p>
      </div>
    </section>

    <section class="section subway-explainer">
      <div class="container" style="max-width: 720px;">
        <div class="subway-explainer-body">
          <p>
            The Subway Birder is how I bird New York City: by MetroCard, in
            public parks, at a respectful distance.
            <a href="/subway-birder/">Read the full intro →</a>
          </p>
          <p>
            Below is the running column: field dispatches, profiles, advocacy
            history, ethics.
          </p>
        </div>
      </div>
    </section>

    <section class="section subway-archive">
      <div class="container" style="max-width: 880px;">
        <h2 class="section-title">Recent dispatches</h2>
        {
          columnNotes.length === 0 ? (
            <p class="subway-archive-empty">
              <em>
                New dispatches start shipping after the manifesto. Subscribe
                below to get them in your inbox.
              </em>
            </p>
          ) : (
            <ul class="notes-list">
              {columnNotes.slice(0, 20).map((note) => {
                const firstBird = note.data.birdsMentioned[0];
                const thumb =
                  note.data.ogImage?.replace(/\.jpg$/i, "-1200.jpg") ??
                  note.data.ogImage;
                return (
                  <li class="notes-card" data-cat={note.data.category}>
                    <a href={`/notes/${note.id}/`} class="notes-card-link">
                      {thumb && (
                        <div class="notes-card-thumb">
                          <img src={thumb} alt="" loading="lazy" />
                        </div>
                      )}
                      <div class="notes-card-text">
                        <div class="notes-card-meta">
                          <span class="notes-card-date">
                            {fmt(note.data.pubDate)}
                          </span>
                          <span class="notes-card-cat">{note.data.category}</span>
                          {firstBird && (
                            <span class="notes-card-bird">
                              {firstBird.commonName}
                            </span>
                          )}
                        </div>
                        <h3 class="notes-card-title">{note.data.title}</h3>
                        <p class="notes-card-dek">{note.data.description}</p>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ul>
          )
        }
      </div>
    </section>

    <section class="section subway-covers">
      <div class="container" style="max-width: 720px;">
        <h2 class="section-title">What this column covers</h2>
        <dl class="subway-covers-list">
          <div>
            <dt>Train lines, not trailheads.</dt>
            <dd>Every post anchors to a subway line or route.</dd>
          </div>
          <div>
            <dt>NYC parks and coastlines.</dt>
            <dd>From Central Park to Jamaica Bay to the Rockaways.</dd>
          </div>
          <div>
            <dt>Seasonal timing.</dt>
            <dd>Fallouts, peaks, shoulder weeks, winter waterfowl.</dd>
          </div>
          <div>
            <dt>Real field logs.</dt>
            <dd>Dates, weather, bird counts, what I missed.</dd>
          </div>
          <div>
            <dt>Photo credit.</dt>
            <dd>My own photos, archived at Macaulay when possible.</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="section subway-author-bio" aria-label="About the author">
      <div class="container" style="max-width: 720px;">
        <AuthorBio />
      </div>
    </section>

    <section class="section notes-subscribe-section subway-subscribe" aria-label="Subscribe">
      <div class="container" style="max-width: 720px;">
        <p class="notes-subscribe-kicker">One dispatch a month</p>
        <h2 class="notes-subscribe-heading">
          Get new Field Notes in your inbox
        </h2>
        <p class="notes-subscribe-copy">
          Free, no sponsors. One NYC bird,<br />one field observation, one link
          worth clicking.
        </p>
        <SubscribeForm buttonLabel="Subscribe" placeholder="you@somewhere.net" />
      </div>
    </section>
  </main>
</BaseLayout>
