{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shellylynnx",
  "main": "./worker.js",
  "compatibility_date": "2026-01-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "unsafe": {
    "bindings": [
      {
        "name": "SUBSCRIBE_RL",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 5, "period": 3600 }
      }
    ]
  }
}
