{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shellylynnx",
  "main": "./worker.js",
  "compatibility_date": "2026-01-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "kv_namespaces": [
    { "binding": "RATE_LIMIT", "id": "7e31ed192b0141e8b5d39947959b3bc6" }
  ]
}
